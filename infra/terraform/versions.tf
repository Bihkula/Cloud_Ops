# Version pins. Keeping these explicit means every teammate runs the same
# provider behaviour — no "works on my machine" drift in generated plans.
terraform {
  required_version = ">= 1.6.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.60"
    }
    random = {
      source  = "hashicorp/random"
      version = "~> 3.6"
    }
  }
}
