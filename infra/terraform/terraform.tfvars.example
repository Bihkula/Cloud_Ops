# Copy to terraform.tfvars and adjust. DO NOT put the DB password here if this
# file could ever be committed — prefer:  export TF_VAR_db_password='...'
#
# terraform.tfvars is gitignored in this repo; keep it that way.

region      = "eu-west-1"
project     = "cloudops"
app_name    = "cirrus"      # <-- change this (and nothing else) for the v2 rebrand
environment = "prod"

vpc_cidr           = "10.0.0.0/16"
az_count           = 2
single_nat_gateway = true

db_name           = "cirrus"
db_username       = "cirrus"
db_instance_class = "db.t3.micro"
db_engine_version = "16.4"
db_allocated_storage = 20

# db_password = "set-me-via-TF_VAR_db_password-instead"
